                    <mxGeometry x="1200" y="893" width="145" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="s7" value="Continuidad&#xa;backup, recuperación, SLA" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;spacing=8;arcSize=16;fillColor=#7F7358;strokeColor=#B8A57D;fontColor=#F5F5F2;" parent="1" vertex="1">
                    <mxGeometry x="1390" y="893" width="180" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="decisiones" value="Decisiones clave&#xa;1. Pasar de gestión manual/dispersa a plataforma centralizada.&#xa;2. Diseñar la reserva como entidad núcleo del negocio.&#xa;3. Separar canal cliente, panel operador y capa de datos.&#xa;4. Digitalizar consentimientos y evidencia de aceptación.&#xa;5. Usar trazabilidad, logs y reportes para control gerencial." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2B3321;strokeColor=#7B8157;fontSize=13;fontColor=#F5F5F2;spacing=12;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="50" y="1050" width="540" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="reflexion" value="Reflexión crítica&#xa;La arquitectura es coherente si cada capa soporta el mismo proceso crítico: reserva → pago → consentimiento → check-in → operación → cierre. El riesgo principal no es solo técnico: es que la operación crezca sin controles, generando errores, baja trazabilidad y dependencia de personas. Por eso seguridad, datos y operación deben diseñarse desde el inicio." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#222222;strokeColor=#7F7358;fontSize=13;fontColor=#F5F5F2;spacing=12;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="620" y="1050" width="680" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="wow" value="Efecto esperado&#xa;Elite Airsoft pasa de operar reservas manuales a una operación digital controlada: más velocidad, menos errores, mejor experiencia del cliente, evidencia auditable y datos para escalar." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B8A57D;strokeColor=#D6C79B;fontSize=13;fontStyle=1;fontColor=#111111;spacing=12;arcSize=10;" parent="1" vertex="1">
                    <mxGeometry x="1330" y="1050" width="395" height="95" as="geometry"/>
                </mxCell>
                <mxCell id="sec-note" value="Seguridad transversal: no es una capa final; gobierna identidad, datos, trazabilidad, pagos, consentimiento y continuidad en todo el flujo." style="text;html=1;strokeColor=#B8A57D;fillColor=#7F7358;fontSize=13;fontStyle=1;fontColor=#F5F5F2;align=center;" parent="1" vertex="1">
