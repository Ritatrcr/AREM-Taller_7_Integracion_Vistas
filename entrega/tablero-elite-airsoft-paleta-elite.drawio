                <mxCell id="title" value="Taller 7 - Integración de Vistas de Arquitectura: Elite Airsoft" style="text;html=1;strokeColor=none;fillColor=none;fontSize=30;fontStyle=1;fontColor=#F5F5F2;align=center;" parent="1" vertex="1">
                    <mxGeometry x="300" y="25" width="1200" height="45" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="Narrativa integrada: reservas, pagos, consentimientos, operación, trazabilidad, infraestructura y seguridad para escalar el negocio con control" style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontColor=#D6D1C6;align=center;" parent="1" vertex="1">
                    <mxGeometry x="260" y="72" width="1280" height="35" as="geometry"/>
                </mxCell>
                <mxCell id="contexto" value="Cliente real: Elite Airsoft&#xa;Empresa de entretenimiento táctico con reservas de partidas, operación en campo, atención por canales digitales, validación de pagos y control de participantes.&#xa;&#xa;Dolor principal: proceso manual y disperso que limita trazabilidad, escalabilidad y control normativo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111111;strokeColor=#B8A57D;fontSize=13;fontColor=#F5F5F2;spacing=14;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="50" y="125" width="390" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="objetivos" value="Objetivos de arquitectura&#xa;• Centralizar reservas y pagos&#xa;• Reducir errores humanos&#xa;• Trazar consentimientos, asistencia y pagos&#xa;• Mejorar decisiones con datos&#xa;• Fortalecer seguridad y cumplimiento&#xa;• Habilitar crecimiento operacional" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B8A57D;strokeColor=#D6C79B;fontSize=13;fontColor=#111111;spacing=14;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="465" y="125" width="350" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="narrativa" value="Narrativa TO-BE&#xa;El cliente reserva en web/app, paga o pre-registra el pago, acepta consentimientos digitales y recibe confirmación. El operador valida desde un panel, realiza check-in con QR, registra asistencia/incidentes y la gerencia visualiza ventas, ocupación y riesgos desde reportes centralizados." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#222222;strokeColor=#7F7358;fontSize=13;fontColor=#F5F5F2;spacing=14;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="840" y="125" width="450" height="170" as="geometry"/>
                </mxCell>
                <mxCell id="referentes" value="Referentes de documentación&#xa;• Vistas y stakeholders: TOGAF&#xa;• Capas negocio / aplicación / tecnología: ArchiMate&#xa;• Zoom técnico: C4 Model&#xa;• Diagramas de referencia cloud y seguridad: AWS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#222222;strokeColor=#7F7358;fontSize=13;fontColor=#F5F5F2;spacing=14;arcSize=12;" parent="1" vertex="1">
                    <mxGeometry x="1315" y="125" width="410" height="170" as="geometry"/>
