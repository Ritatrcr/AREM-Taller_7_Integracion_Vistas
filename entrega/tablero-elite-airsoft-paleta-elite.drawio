                    <mxGeometry x="860" y="893" width="145" height="55" as="geometry"/>
                </mxCell>
                <mxCell id="s5" value="Conciliación antifraude&#xa;pagos vs reservas" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;align=center;spacing=8;arcSize=16;fillColor=#7F7358;strokeColor=#B8A57D;fontColor=#F5F5F2;" parent="1" vertex="1">
                    <mxGeometry x="1030" y="893" width="145" height="55" as="geometry"/>
