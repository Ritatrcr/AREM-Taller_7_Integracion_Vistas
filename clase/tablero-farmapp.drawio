        <mxCell id="title" value="FarmApp - Integración de Vistas de Arquitectura" style="text;html=1;strokeColor=none;fillColor=none;fontSize=30;fontStyle=1;fontColor=#0F172A;align=center;" vertex="1" parent="1">
