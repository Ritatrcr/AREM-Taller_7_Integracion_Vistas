        <mxCell id="subtitle" value="Cadena de farmacias con e-commerce integrado a puntos físicos, inventario, CRM, pagos y logística" style="text;html=1;strokeColor=none;fillColor=none;fontSize=15;fontColor=#475569;align=center;" vertex="1" parent="1">
          <mxGeometry x="260" y="75" width="1080" height="35" as="geometry"/>
        </mxCell>

        <mxCell id="context" value="Objetivo de negocio&#xa;• Servicio omnicanal consistente&#xa;• Inventario disponible en tiempo real&#xa;• Pedidos trazables desde compra hasta entrega&#xa;• Recomendaciones y promociones personalizadas&#xa;• Seguridad en pagos y datos personales" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E0F2FE;strokeColor=#0284C7;fontSize=14;fontColor=#0F172A;spacing=12;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="55" y="120" width="350" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="narrative" value="Narrativa central&#xa;El cliente consulta productos, compra por app/web, valida prescripción si aplica, paga digitalmente y recibe despacho con rastreo. Internamente, la operación sincroniza POS, inventario, CRM, pagos y logística sobre infraestructura disponible y controles de seguridad transversales." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#CBD5E1;fontSize=14;fontColor=#334155;spacing=12;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="445" y="120" width="700" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="legend" value="Lectura del tablero&#xa;1. Negocio define el flujo de valor.&#xa;2. Información captura y conecta datos críticos.&#xa;3. Aplicaciones ejecutan la operación.&#xa;4. Infraestructura asegura disponibilidad.&#xa;5. Seguridad gobierna todo el modelo." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F1F5F9;strokeColor=#CBD5E1;fontSize=13;fontColor=#334155;spacing=12;arcSize=12;" vertex="1" parent="1">
          <mxGeometry x="1185" y="120" width="355" height="150" as="geometry"/>
